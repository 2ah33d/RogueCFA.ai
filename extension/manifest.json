{
  "manifest_version": 3,
  "name": "RogueCFA MarketCall Digest",
  "version": "1.0.0",
  "description": "Extract YouTube transcripts from your browser and generate MarketCall stock pick digests via RogueCFA.ai",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
